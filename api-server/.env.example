# Sao chép file này thành .env và điền thông tin

# JWT Secret — đổi thành chuỗi ngẫu nhiên dài trong production
JWT_SECRET=benhvien_jwt_secret_change_this_in_production

# JWT hết hạn sau
JWT_EXPIRES_IN=8h

# Port server lắng nghe
PORT=3000

# Đường dẫn tới file Service Account Key
# Tải từ Firebase Console → Project Settings → Service accounts → Generate new private key
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
